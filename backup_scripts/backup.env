# Copy this file to backup.env and customize values for your environment.

# Environment label used in backup filenames.
BACKUP_ENVIRONMENT=development

# Base directory where local backups and logs are stored.
BACKUP_BASE_DIR=/var/backups/dittravel
BACKUP_LOG_FILE=/var/backups/dittravel/backup.log

# Keep backups newer than this number of days.
MARIADB_RETENTION_DAYS=14
MONGODB_RETENTION_DAYS=14

# Source mode:
# - local: connect directly to localhost/remote host using mysqldump/mongodump
# - docker: execute dump inside docker compose services
# - auto: try docker service first, fallback to local
MARIADB_SOURCE=auto
MONGODB_SOURCE=auto

# Directory containing docker-compose.yml for DB services.
COMPOSE_PROJECT_DIR=/home/dittravel/TC3005B.501-Backend
MARIADB_DOCKER_SERVICE=mariadb
MONGODB_DOCKER_SERVICE=mongodb

# MariaDB connection settings.
MARIADB_DB_NAME=CocoScheme
MARIADB_USER=travel_user
MARIADB_PASSWORD=supersecret
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_BACKUP_SUBDIR=mariadb

# MongoDB connection settings.
MONGODB_DB_NAME=fileStorage
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_AUTH_DB=admin
MONGODB_BACKUP_SUBDIR=mongodb

# Remote copy (optional). Disable with false if not needed.
REMOTE_BACKUP_ENABLED=false
REMOTE_BACKUP_HOST=
REMOTE_BACKUP_USER=
REMOTE_BACKUP_TARGET_DIR=/var/backups/dittravel
# Optional SSH private key path. Leave empty to use default ssh agent/key.
REMOTE_BACKUP_SSH_KEY=

# Automatic schedule (cron expression), configurable by superadmin.
# Set false to remove cron job automatically.
BACKUP_AUTOMATION_ENABLED=true
# Every 6 hours by default.
BACKUP_CRON_SCHEDULE="0 */3 * * *"

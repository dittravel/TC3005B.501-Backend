# Docker profile (for docker compose in backend project)
PORT=3000
NODE_ENV=development
FRONTEND_URL=https://localhost:4321
BACKEND_URL=https://localhost:3000

# Shared DB credentials used by mariadb + backend container
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_ROOT_PASSWORD=your_db_root_password

# Host ports exposed by docker compose (safe defaults to avoid local conflicts)
DB_DOCKER_PORT=3307
MONGO_DOCKER_PORT=27018

# Security and auth
AES_SECRET_KEY=12345678901234567890123456789012
AES_IV=1234567890123456
JWT_SECRET=your_jwt_secret_key_here

# Mail
MAIL_USER=your_mail_user@example.com
MAIL_PASSWORD=your_mail_app_password

# Optional API integrations
BANXICO_API_KEY=
BANXICO_API_URL=https://www.banxico.org.mx/SieAPIRest/service/v1/
BANXICO_CACHE_TTL=3600
DUFFEL_TOKEN=
VALIDA_CFDI_API_KEY=

# Flight search page size default
FLIGHT_SEARCH_PAGE_SIZE=10

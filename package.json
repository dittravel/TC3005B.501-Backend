{
    "name": "tc3005b-501-backend",
    "version": "0.1.0",
    "type": "module",
    "description": "API and Database for the conection and the functioning of the trip management system portal developed in course TC3005B by group 501.",
    "main": "index.js",
    "scripts": {
        "start": "nodemon index.js",
        "dev": "nodemon index.js",
        "dummy_db": "node ./database/config/dev_db.js dev",
        "empty_db": "node ./database/config/dev_db.js prod",
        "test": "node --test",
        "test:policy": "node --test tests/reimbursementPolicyService.test.js",
        "test:erp": "node --test tests/integration*.test.js",
        "test:audit": "node --test tests/auditLog*.test.js",
        "prisma:generate": "prisma generate",
        "prisma:migrate:deploy": "prisma migrate deploy",
        "prisma:seed": "npx prisma generate && node prisma/seed.js",
        "prisma:seed:dummy": "npx prisma generate && node prisma/seedDummy.js",
        "docker:start:prisma": "node docker-start.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/yourusername/TC3005B.501-Backend.git"
    },
    "keywords": [
        "travel",
        "management",
        "system",
        "api"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@prisma/adapter-mariadb": "^7.7.0",
        "@prisma/adapter-pg": "^7.7.0",
        "@prisma/client": "^7.7.0",
        "axios": "^1.13.6",
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "csv-parse": "^5.6.0",
        "dotenv": "^16.6.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.5.0",
        "express-validator": "^7.2.1",
        "jsonwebtoken": "^9.0.2",
        "mariadb": "^3.4.1",
        "mongo-sanitize": "^1.1.0",
        "mongodb": "^5.0.0",
        "multer": "^2.0.1",
        "nodemailer": "^7.0.3",
        "xlsx": "^0.18.5",
        "xml2js": "^0.6.2"
    },
    "devDependencies": {
        "@types/node": "^25.5.2",
        "nodemon": "^3.0.1",
        "prisma": "^7.7.0"
    },

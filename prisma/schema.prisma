generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Alert {
  alert_id     Int           @id @default(autoincrement())
  request_id   Int?
  message_id   Int?
  alert_date   DateTime?     @default(now()) @db.Timestamp(0)
  AlertMessage AlertMessage? @relation(fields: [message_id], references: [message_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_alert_message")
  Request      Request?      @relation(fields: [request_id], references: [request_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_alert_request")

  @@index([message_id], map: "fk_alert_message")
  @@index([request_id], map: "fk_alert_request")
}

model AlertMessage {
  message_id   Int     @id @default(autoincrement())
  message_text String  @db.VarChar(60)
  Alert        Alert[]
}

model Audit_Log {
  audit_log_id    Int       @id @default(autoincrement())
  actor_user_id   Int?
  action_type     String    @db.VarChar(80)
  entity_type     String    @db.VarChar(80)
  entity_id       String?   @db.VarChar(64)
  source_ip       String?   @db.VarChar(45)
  metadata        String?   @db.LongText
  event_timestamp DateTime? @default(now()) @db.Timestamp(0)
  User            User?     @relation(fields: [actor_user_id], references: [user_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_audit_actor_user")

  @@index([action_type], map: "idx_audit_action")
  @@index([actor_user_id], map: "idx_audit_actor")
  @@index([entity_type, entity_id], map: "idx_audit_entity")
  @@index([event_timestamp], map: "idx_audit_timestamp")
}

model AuthorizationRule {
  rule_id           Int                            @id @default(autoincrement())
  rule_name         String                         @db.VarChar(50)
  is_default        Boolean                        @default(false)
  num_levels        Int
  automatic         Boolean                        @default(true)
  travel_type       AuthorizationRule_travel_type?
  min_duration      Int?
  max_duration      Int?
  min_amount        Float?                         @db.Float
  max_amount        Float?                         @db.Float
  society_group_id  Int?
  SocietyGroup      SocietyGroup?                  @relation(fields: [society_group_id], references: [id])
  levels            AuthorizationRuleLevel[]
  Request           Request[]

  @@index([society_group_id])
}

model AuthorizationRuleLevel {
  id                    Int                               @id @default(autoincrement())
  rule_id               Int
  level_number          Int
  level_type            AuthorizationRuleLevel_level_type
  superior_level_number Int?
  AuthorizationRule     AuthorizationRule                 @relation(fields: [rule_id], references: [rule_id], onUpdate: Restrict, map: "fk_authorization_rule")

  @@index([rule_id], map: "fk_authorization_rule")
}

model City {
  city_id    Int     @id @default(autoincrement())
  city_name  String  @unique(map: "city_name") @db.VarChar(200)
  routesTo   Route[] @relation("DestinationCity")
  routesFrom Route[] @relation("OriginCity")
}

model CostCenter {
  cost_center_id   Int            @id @default(autoincrement())
  cost_center_name String         @db.VarChar(20)
  society_group_id Int?
  SocietyGroup     SocietyGroup?  @relation(fields: [society_group_id], references: [id], map: "fk_costcenter_societygroup")
  Department       Department[]
  Account          Account[]

  @@unique([cost_center_name, society_group_id])
  @@index([society_group_id])
}

model Country {
  country_id   Int     @id @default(autoincrement())
  country_name String  @unique(map: "country_name") @db.VarChar(60)
  routesTo     Route[] @relation("DestinationCountry")
  routesFrom   Route[] @relation("OriginCountry")
}

model Currency {
  currency_id       Int                 @id @default(autoincrement())
  currency_code     String              @unique(map: "currency_code") @db.VarChar(6)
  currency_name     String              @db.VarChar(100)
  country           String?             @db.VarChar(100)
  banxico_series_id String?             @db.VarChar(20)
  frequency         Currency_frequency? @default(monthly)
  active            Boolean             @default(true)
}

model Department {
  department_id                   Int                               @id @default(autoincrement())
  department_name                 String                            @db.VarChar(20)
  cost_center_id                  Int?
  society_group_id                Int?
  active                          Boolean                           @default(true)
  CostCenter                      CostCenter?                       @relation(fields: [cost_center_id], references: [cost_center_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_department_costcenter")
  SocietyGroup                    SocietyGroup?                     @relation(fields: [society_group_id], references: [id], map: "fk_department_societygroup")
  Reimbursement_Policy_Assignment Reimbursement_Policy_Assignment[]
  User                            User[]

  @@unique([department_name, society_group_id])
  @@index([cost_center_id], map: "fk_department_costcenter")
  @@index([society_group_id])
}

model Permission {
  permission_id   Int               @id @default(autoincrement())
  permission_key  String            @db.VarChar(50)
  permission_name String            @db.VarChar(100)
  module          String            @db.VarChar(50)
  action          String            @db.VarChar(50)
  description     String?           @db.VarChar(100)
  society_group_id Int?
  SocietyGroup    SocietyGroup?     @relation(fields: [society_group_id], references: [id], map: "fk_permission_societygroup")
  Role_Permission Role_Permission[]

  @@unique([permission_key, society_group_id])
  @@index([society_group_id])
}

model Receipt {
  receipt_id          Int                   @id @default(autoincrement())
  receipt_type_id     Int?
  request_id          Int?
  route_id            Int?
  society_id          Int?
  validation          Receipt_validation?   @default(Pendiente)
  amount              Float                 @db.Float
  currency            String?               @db.VarChar(6)
  refund              Boolean?              @default(true)
  submission_date     DateTime?             @default(now()) @db.Timestamp(0)
  validation_date     DateTime?             @db.Timestamp(0)
  pdf_file_id         String?               @db.VarChar(24)
  pdf_file_name       String?               @db.VarChar(255)
  xml_file_id         String?               @db.VarChar(24)
  xml_file_name       String?               @db.VarChar(255)
  xml_uuid            String?               @unique(map: "xml_uuid") @db.VarChar(36)
  xml_rfc_emisor      String?               @db.VarChar(13)
  xml_rfc_receptor    String?               @db.VarChar(13)
  xml_nombre_emisor   String?               @db.VarChar(255)
  xml_fecha           DateTime?             @db.DateTime(0)
  xml_total           Decimal?              @db.Decimal(15, 2)
  xml_subtotal        Decimal?              @db.Decimal(15, 2)
  xml_impuestos       Decimal?              @db.Decimal(15, 2)
  xml_moneda          String?               @db.VarChar(6)
  Request             Request?              @relation(fields: [request_id], references: [request_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_receipt_request")
  Route               Route?                @relation(fields: [route_id], references: [route_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_receipt_route")
  Receipt_Type        Receipt_Type?         @relation(fields: [receipt_type_id], references: [receipt_type_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_receipt_type")
  Society             Society?              @relation(fields: [society_id], references: [id], map: "fk_receipt_society")
  ReceiptType_Account ReceiptType_Account[]

  @@index([request_id], map: "fk_receipt_request")
  @@index([route_id], map: "fk_receipt_route")
  @@index([receipt_type_id], map: "fk_receipt_type")
  @@index([society_id])
}

model Receipt_Type {
  receipt_type_id           Int                         @id @default(autoincrement())
  receipt_type_name         String                      @unique @db.VarChar(20)
  Receipt                   Receipt[]
  ReceiptType_Account       ReceiptType_Account[]
  Reimbursement_Policy_Rule Reimbursement_Policy_Rule[]
}

model Reimbursement_Policy {
  policy_id                       Int                               @id @default(autoincrement())
  policy_code                     String                            @unique(map: "policy_code") @db.VarChar(40)
  policy_name                     String                            @db.VarChar(120)
  description                     String?                           @db.LongText
  base_currency                   String                            @default("MXN") @db.VarChar(6)
  effective_from                  DateTime                          @db.Date
  effective_to                    DateTime?                         @db.Date
  active                          Boolean                           @default(true)
  created_by                      Int?
  society_group_id                Int?
  creation_date                   DateTime?                         @default(now()) @db.Timestamp(0)
  last_mod_date                   DateTime?                         @default(now()) @db.Timestamp(0)
  User                            User?                             @relation(fields: [created_by], references: [user_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_reimbursement_policy_user")
  SocietyGroup                    SocietyGroup?                     @relation(fields: [society_group_id], references: [id], map: "fk_reimbursement_policy_societygroup")
  Reimbursement_Policy_Assignment Reimbursement_Policy_Assignment[]
  Reimbursement_Policy_Rule       Reimbursement_Policy_Rule[]

  @@index([created_by], map: "fk_reimbursement_policy_user")
  @@index([society_group_id])
}

model Reimbursement_Policy_Assignment {
  assignment_id        Int                  @id @default(autoincrement())
  policy_id            Int
  department_id        Int?
  active               Boolean              @default(true)
  creation_date        DateTime?            @default(now()) @db.Timestamp(0)
  Department           Department?          @relation(fields: [department_id], references: [department_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_policy_assignment_department")
  Reimbursement_Policy Reimbursement_Policy @relation(fields: [policy_id], references: [policy_id], onUpdate: Restrict, map: "fk_policy_assignment_policy")

  @@index([department_id], map: "fk_policy_assignment_department")
  @@index([policy_id], map: "fk_policy_assignment_policy")
}

model Reimbursement_Policy_Rule {
  rule_id                   Int                                  @id @default(autoincrement())
  policy_id                 Int
  receipt_type_id           Int
  trip_scope                Reimbursement_Policy_Rule_trip_scope @default(TODOS)
  max_amount_mxn            Decimal                              @db.Decimal(15, 2)
  submission_deadline_days  Int?
  requires_xml              Boolean                              @default(false)
  allow_foreign_without_xml Boolean                              @default(true)
  refundable                Boolean                              @default(true)
  active                    Boolean                              @default(true)
  creation_date             DateTime?                            @default(now()) @db.Timestamp(0)
  last_mod_date             DateTime?                            @default(now()) @db.Timestamp(0)
  Reimbursement_Policy      Reimbursement_Policy                 @relation(fields: [policy_id], references: [policy_id], onUpdate: Restrict, map: "fk_policy_rule_policy")
  Receipt_Type              Receipt_Type                         @relation(fields: [receipt_type_id], references: [receipt_type_id], onUpdate: Restrict, map: "fk_policy_rule_receipt_type")

  @@index([policy_id], map: "fk_policy_rule_policy")
  @@index([receipt_type_id], map: "fk_policy_rule_receipt_type")
}

model Request {
  request_id            Int                @id @default(autoincrement())
  user_id               Int?
  request_status_id     Int?               @default(1)
  assigned_to           Int?
  authorization_level   Int?               @default(0)
  authorization_rule_id Int?
  society_id            Int?
  notes                 String?            @db.LongText
  requested_fee         Float?             @db.Float
  imposed_fee           Float?             @db.Float
  request_days          Float?             @db.Float
  creation_date         DateTime?          @default(now()) @db.Timestamp(0)
  last_mod_date         DateTime?          @default(now()) @db.Timestamp(0)
  active                Boolean            @default(true)
  Alert                 Alert[]
  Receipt               Receipt[]
  assignedUser          User?              @relation("AssignedUser", fields: [assigned_to], references: [user_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_request_assigned_user")
  AuthorizationRule     AuthorizationRule? @relation(fields: [authorization_rule_id], references: [rule_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_request_auth_rule")
  Request_status        Request_status?    @relation(fields: [request_status_id], references: [request_status_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_request_status")
  requester             User?              @relation("RequesterUser", fields: [user_id], references: [user_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_request_user")
  Society              Society?            @relation(fields: [society_id], references: [id], map: "fk_request_society")
  Route_Request         Route_Request[]

  @@index([assigned_to], map: "fk_request_assigned_user")
  @@index([authorization_rule_id], map: "fk_request_auth_rule")
  @@index([request_status_id], map: "fk_request_status")
  @@index([user_id], map: "fk_request_user")
  @@index([society_id])
}

model Request_status {
  request_status_id Int       @id @default(autoincrement())
  status            String    @unique(map: "status") @db.VarChar(30)
  Request           Request[]
}

model Role {
  role_id         Int               @id @default(autoincrement())
  role_name       String            @db.VarChar(60)
  description     String?           @db.VarChar(60)
  society_group_id Int?
  active          Boolean?          @default(true)
  updated_at      DateTime?         @default(now()) @db.Timestamp(0)
  SocietyGroup    SocietyGroup?     @relation(fields: [society_group_id], references: [id], map: "fk_role_societygroup")
  Role_Permission Role_Permission[]
  User            User[]

  @@unique([role_name, society_group_id])
  @@index([active], map: "idx_role_active")
  @@index([society_group_id])
}

model Role_Permission {
  role_permission_id Int        @id @default(autoincrement())
  role_id            Int
  permission_id      Int
  granted_at         DateTime   @default(now()) @db.Timestamp(0)
  Permission         Permission @relation(fields: [permission_id], references: [permission_id], onDelete: Cascade, map: "fk_role_permission_permission")
  Role               Role       @relation(fields: [role_id], references: [role_id], onDelete: Cascade, map: "fk_role_permission_role")

  @@unique([role_id, permission_id], map: "uq_role_permission")
  @@index([permission_id], map: "fk_role_permission_permission")
}

model Route {
  route_id               Int             @id @default(autoincrement())
  id_origin_country      Int?
  id_origin_city         Int?
  id_destination_country Int?
  id_destination_city    Int?
  router_index           Int?
  plane_needed           Boolean         @default(false)
  hotel_needed           Boolean         @default(false)
  beginning_date         DateTime?       @db.Date
  beginning_time         DateTime?       @db.Time(0)
  ending_date            DateTime?       @db.Date
  ending_time            DateTime?       @db.Time(0)
  Receipt                Receipt[]
  destinationCity        City?           @relation("DestinationCity", fields: [id_destination_city], references: [city_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_route_destination_city")
  destinationCountry     Country?        @relation("DestinationCountry", fields: [id_destination_country], references: [country_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_route_destination_country")
  originCity             City?           @relation("OriginCity", fields: [id_origin_city], references: [city_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_route_origin_city")
  originCountry          Country?        @relation("OriginCountry", fields: [id_origin_country], references: [country_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_route_origin_country")
  Route_Request          Route_Request[]

  @@index([id_destination_city], map: "fk_route_destination_city")
  @@index([id_destination_country], map: "fk_route_destination_country")
  @@index([id_origin_city], map: "fk_route_origin_city")
  @@index([id_origin_country], map: "fk_route_origin_country")
}

model Route_Request {
  route_request_id Int      @id @default(autoincrement())
  request_id       Int?
  route_id         Int?
  Request          Request? @relation(fields: [request_id], references: [request_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_route_request_request")
  Route            Route?   @relation(fields: [route_id], references: [route_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_route_request_route")

  @@index([request_id], map: "fk_route_request_request")
  @@index([route_id], map: "fk_route_request_route")
}

model User {
  user_id                             Int                    @id @default(autoincrement())
  role_id                             Int?
  department_id                       Int?
  boss_id                             Int?
  substitute_id                       Int?
  out_of_office_start_date            DateTime?              @db.Date
  out_of_office_end_date              DateTime?              @db.Date
  user_name                           String                 @unique(map: "user_name") @db.VarChar(60)
  password                            String                 @db.VarChar(60)
  workstation                         String?                @db.VarChar(20)
  email                               String                 @unique(map: "email") @db.VarChar(254)
  phone_number                        String?                @db.VarChar(254)
  wallet                              Float?                 @default(0) @db.Float
  creation_date                       DateTime?              @default(now()) @db.Timestamp(0)
  last_mod_date                       DateTime?              @default(now()) @db.Timestamp(0)
  active                              Boolean                @default(true)
  password_reset_token                String?                @db.VarChar(64)
  password_reset_expires              DateTime?              @db.DateTime(0)
  society_id                          Int?                   @db.Int
  Society                             Society?               @relation(fields: [society_id], references: [id])
  Audit_Log                           Audit_Log[]
  Reimbursement_Policy                Reimbursement_Policy[]
  requestsAssigned                    Request[]              @relation("AssignedUser")
  requestsCreated                     Request[]              @relation("RequesterUser")
  boss                                User?                  @relation("UserBoss", fields: [boss_id], references: [user_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_user_boss")
  subordinates                        User[]                 @relation("UserBoss")
  department                          Department?            @relation(fields: [department_id], references: [department_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_user_department")
  role                                Role?                  @relation(fields: [role_id], references: [role_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_user_role")
  substitute                          User?                  @relation("UserSubstitute", fields: [substitute_id], references: [user_id], onDelete: Restrict, onUpdate: Restrict, map: "fk_user_substitute")
  substitutedBy                       User[]                 @relation("UserSubstitute")

  @@index([boss_id], map: "fk_user_boss")
  @@index([department_id], map: "fk_user_department")
  @@index([role_id], map: "fk_user_role")
  @@index([substitute_id], map: "fk_user_substitute")
}

model SocietyGroup {
  id                   Int                    @id @default(autoincrement())
  description          String?                @db.VarChar(255)
  is_default           Boolean                @default(false)
  Society              Society[]
  AuthorizationRule    AuthorizationRule[]
  Reimbursement_Policy Reimbursement_Policy[]
  CostCenter           CostCenter[]
  Department           Department[]
  Role                 Role[]
  Permission           Permission[]
  Account              Account[]
}

model Society {
  id                Int     @id @default(autoincrement())
  description       String  @db.VarChar(20)
  local_currency    String  @db.VarChar(6)
  society_group_id  Int?
  is_default        Boolean @default(false)
  SocietyGroup      SocietyGroup? @relation(fields: [society_group_id], references: [id])
  User              User[]
  Request           Request[]
  Receipt           Receipt[]
}

model Account {
  account_id          Int                   @id @default(autoincrement())
  account_code        String                @unique @db.VarChar(20)
  account_name        String                @db.VarChar(100)
  account_type        String                @db.VarChar(50)
  description         String?               @db.VarChar(255)
  society_group_id    Int?
  cost_center_id      Int?
  active              Boolean               @default(true)
  created_at          DateTime              @default(now())
  last_mod_date       DateTime              @default(now())
  SocietyGroup        SocietyGroup?         @relation(fields: [society_group_id], references: [id], map: "fk_account_societygroup")
  CostCenter          CostCenter?           @relation(fields: [cost_center_id], references: [cost_center_id], map: "fk_account_costcenter")
  ReceiptType_Account ReceiptType_Account[]

  @@index([society_group_id])
  @@index([cost_center_id])
}

model ReceiptType_Account {
  receipttype_account_id Int          @id @default(autoincrement())
  receipt_type_id        Int
  account_id             Int
  is_default             Boolean      @default(false)
  active                 Boolean      @default(true)
  receiptReceipt_id      Int?
  taxTax_id              Int?
  Account                Account      @relation(fields: [account_id], references: [account_id])
  Receipt                Receipt?     @relation(fields: [receiptReceipt_id], references: [receipt_id])
  Receipt_Type           Receipt_Type @relation(fields: [receipt_type_id], references: [receipt_type_id])
  Tax                    Tax?         @relation(fields: [taxTax_id], references: [tax_id])

  @@unique([receipt_type_id, account_id])
  @@index([account_id], map: "ReceiptType_Account_account_id_fkey")
  @@index([receiptReceipt_id], map: "ReceiptType_Account_receiptReceipt_id_fkey")
  @@index([taxTax_id], map: "ReceiptType_Account_taxTax_id_fkey")
}

model Tax {
  tax_id              Int                   @id @default(autoincrement())
  tax_code            String                @unique @db.VarChar(30)
  tax_name            String                @db.VarChar(100)
  tax_rate            Decimal               @db.Decimal(10, 4)
  description         String?               @db.VarChar(255)
  active              Boolean               @default(true)
  created_at          DateTime              @default(now())
  last_mod_date       DateTime              @default(now())
  ReceiptType_Account ReceiptType_Account[]
}

enum Reimbursement_Policy_Rule_trip_scope {
  NACIONAL
  INTERNACIONAL
  TODOS
}

enum AuthorizationRuleLevel_level_type {
  Jefe
  Aleatorio
  Nivel_Superior @map("Nivel Superior")
}

enum Receipt_validation {
  Pendiente
  Aprobado
  Rechazado
}

enum Currency_frequency {
  daily
  monthly
}

enum AuthorizationRule_travel_type {
  Nacional
  Internacional
  Todos
}

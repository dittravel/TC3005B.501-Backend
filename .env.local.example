# Local development profile (without Docker)
PORT=3000
NODE_ENV=development
FRONTEND_URL=https://localhost:4321
BACKEND_URL=https://localhost:3000

# Local MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Local MongoDB
MONGO_URI=mongodb://localhost:27017

# Security and auth
AES_SECRET_KEY=12345678901234567890123456789012
AES_IV=1234567890123456
JWT_SECRET=your_jwt_secret_key_here

# Mail
MAIL_USER=your_mail_user@example.com
MAIL_PASSWORD=your_mail_app_password

# Optional API integrations
BANXICO_API_KEY=
BANXICO_API_URL=https://www.banxico.org.mx/SieAPIRest/service/v1/
BANXICO_CACHE_TTL=3600
DUFFEL_TOKEN=
VALIDA_CFDI_API_KEY=

# Flight search page size default
FLIGHT_SEARCH_PAGE_SIZE=10

# Prisma connection string (must match DB_* values)
DATABASE_URL="mysql://your_db_user:your_db_password@localhost:3306/your_db_name"
DATABASE_USER="your_db_user"
DATABASE_PASSWORD="your_db_password"
DATABASE_NAME="your_db_name"
DATABASE_HOST="localhost"
DATABASE_PORT=3306
